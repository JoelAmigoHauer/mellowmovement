# Sanity CMS — create a project at https://www.sanity.io/manage or `npx sanity@latest init`
# The site works without these (bundled fallback content); set them to enable /studio + live editing.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Write token (only needed to run `node scripts/seed-sanity.mjs` to seed initial content).
# Create at https://www.sanity.io/manage → API → Tokens (Editor permission). Do NOT commit.
SANITY_API_WRITE_TOKEN=
